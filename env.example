# ShadowTalk AI - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# FRONTEND VARIABLES (Required)
# ============================================
# These are auto-configured by Lovable Cloud - do not modify
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id

# ============================================
# BACKEND SECRETS (Set in Lovable Cloud Secrets)
# ============================================
# These should be added via Lovable Cloud > Secrets

# AI Gateway (Required - Automatically provided by Lovable)
# LOVABLE_API_KEY=auto_provided

# Deep Research (Optional - for web search)
# SERP_API_KEY=your_serp_api_key

# Web Search (Optional - alternative to SERP)
# GOOGLE_SEARCH_API_KEY=your_google_search_key
# GOOGLE_SEARCH_ENGINE_ID=your_cse_id

# Email Notifications (Optional)
# SENDGRID_API_KEY=your_sendgrid_key
# RESEND_API_KEY=your_resend_key

# OAuth Integrations (Optional - for email/calendar sync)
# GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
# GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# MICROSOFT_OAUTH_CLIENT_ID=your_microsoft_oauth_client_id
# MICROSOFT_OAUTH_CLIENT_SECRET=your_microsoft_oauth_client_secret

# LemonSqueezy Payments (Optional)
# LEMONSQUEEZY_API_KEY=your_lemonsqueezy_key
# LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
# LEMONSQUEEZY_STORE_ID=your_store_id

# ============================================
# SECURITY NOTES
# ============================================
# 1. NEVER commit this file with real values to git
# 2. Rotate all keys if they have been exposed
# 3. Use Lovable Cloud Secrets for backend keys
# 4. Frontend keys (VITE_*) are public, only use anon keys
