{
  "appId": "com.shadowtalk.ai",
  "productName": "ShadowTalk AI",
  "copyright": "Copyright © ShadowTalk AI",
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "publish": {
    "provider": "github",
    "owner": "zain836",
    "repo": "shadowtalk-ai-903ca615"
  },
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "assets/appIcon.ico",
    "uninstallerIcon": "assets/appIcon.ico"
  },
  "win": {
    "target": ["nsis"],
    "icon": "assets/appIcon.ico",
    "publisherName": "ShadowTalk AI"
  },
  "mac": {
    "category": "public.app-category.productivity",
    "target": ["dmg"],
    "icon": "assets/appIcon.png",
    "hardenedRuntime": true
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Office"
  }
}
